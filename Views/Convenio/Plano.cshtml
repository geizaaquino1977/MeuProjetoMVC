    <!-- SCRIPT DA BUSCA -->
    <script>

        // pega o campo de busca
        const campoBusca = document.getElementById("buscaPlano");

        // quando digitar
        campoBusca.addEventListener("keyup", function () {

            // texto digitado (minúsculo)
            const textoBusca = campoBusca.value.toLowerCase();

            // pega todas as linhas da tabela
            const linhas = document.querySelectorAll("#tabelaPlanos tr");

            // percorre todas as linhas
            for (let i = 1; i < linhas.length; i++) {

                const linha = linhas[i];

                const conteudo = linha.textContent.toLowerCase();

                // verifica se contém o texto
                if (conteudo.includes(textoBusca)) {
                    linha.style.display = "";
                } else {
                    linha.style.display = "none";
                }
            }
        });

    </script>
   

</body>
</html>