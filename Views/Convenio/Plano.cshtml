                <tr><td>GreenLine</td><td>Regional</td><td>Ativo</td></tr>
                <tr><td>Medial Saúde</td><td>Regional</td><td>Restrito</td></tr>
                <tr><td>Assim Saúde</td><td>Regional</td><td>Ativo</td></tr>
                <tr><td>Santa Helena Saúde</td><td>Regional</td><td>Ativo</td></tr>
                <tr><td>Intermédica Smart</td><td>Empresarial</td><td>Ativo</td></tr>
