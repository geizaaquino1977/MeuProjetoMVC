

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Clínica Bem Estar</title>
    <link rel="stylesheet" href="/css/clinica.css">
    <style>
       

        /* FUNDO ESCURO */
        .modal {
            display: block; /* já começa aberto */
            position: fixed;
            z-index: 10;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.7);
        }

        /* CAIXA */
        .modal-content {
            background-color: rgba(255,255,255,0.7);
            width: 600px;
            margin:200px auto;
            padding: 30px;
            border-radius: 10px;
            text-align: justify;
        }

        h3{
            font-size:20px;
        }

        .login-box {
            display: block;
            margin-top: 15px;
            
            padding: 30px;
            border-radius: 10px;
            width: 500px;
            
        }

        input {
            width: 100%;
            padding: 10px;
            margin: 10px 0 20px 0;
            border-radius: 5px;
            border: 1px solid #ccc;
        }

        button {
            width: 88%;
            
            padding: 10px;
            background: #4A7DBB;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

            button:hover {
                background: #3b6aa4;
            }
    </style>

</head>
<body>

    <div class="modal">

   
        <div class="modal-content">

    <div class="titulo">CLÍNICA BEM ESTAR</div>

   
        
    <form asp-controller="Home" asp-action="Privacy" method="post placeholder="Digite seu login">

       

    <div class="login-box">
        <h3>LOGIN</h3>

        <input type="text" id="usuario">
        <h3>SENHA</h3>
        <input type="password" id="senha">
        <p></p>

        

        <p id="msg"></p>
                    <button type="button" onclick="login()">ENTRAR</button></div>

            </form>
            </div>
            </div>
            <script>
                async function login() {

                    const usuario = document.getElementById("usuario").value;
                    const senha = document.getElementById("senha").value;

                    try {
                        const response = await fetch("/Home/LoginAjax", {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json"
                            },
                            body: JSON.stringify({
                                usuario: usuario,
                                senha: senha
                            })
                        });

                        const data = await response.json();

                        console.log(data);

                        if (data.sucesso === true) {
                            window.location.href = "/Home/Privacy";
                        } else {
                            document.getElementById("msg").innerText = "Usuário ou senha inválidos";
                        }

                    } catch (erro) {
                        console.error("Erro:", erro);
                        document.getElementById("msg").innerText = "Erro no login";
                    }
                }
            </script>
</body>
</html>