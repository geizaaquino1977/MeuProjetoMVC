<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Aviso de Consulta</title>
    <link rel="stylesheet" href="/css/site.css">
    <style>
        /* ===== FORMULÁRIO AVISO DE CONSULTA ===== */

        .container {
            max-width: 800px;
            margin: 20px auto;
        }

        /* área do formulário */
        form {
            margin-top: 15px;
        }

        /* remove aquele fundo cinza estranho */
        label {
            display: block;
            margin-top: 15px;
            margin-bottom: 5px;
            background: none;
            color: #333;
            font-weight: bold;
        }

        /* campos */
        input {
            width: 200%;
            max-width: 100%;
            padding: 10px;
            border-radius: 6px;
            border: 1px solid #5b8db8;
            background: white;
        }

            /* botão salvar */
            button,
            input[type="submit"] {
                margin-top: 15px;
                padding: 10px 20px;
                background-color: #5b8db8;
                color: white;
                border: none;
                border-radius: 6px;
                cursor: pointer;
            }

                button:hover,
                input[type="submit"]:hover {
                    background-color: #47739a;
                }

        /* títulos */
        h1, h2 {
            text-align: center;
            color: #2c5aa0;
            margin-bottom: 10px;
        }

        /* tabela mais limpa */
        table {
            width: 100%;
            margin-top: 15px;
            border-collapse: collapse;
            background: rgba(255,255,255,0.9);
        }

            table th, table td {
                padding: 10px;
                text-align: left;
            }

            table thead {
                background-color: #5b8db8;
                color: white;
            }

        
    </style>
</head>
<body>

    <h1>Aviso de Consulta</h1>

    <h3>Enviar Aviso</h3>

    Paciente:
    <input type="text" id="paciente">
    <br>
    <br>
    Telefone (WhatsApp):
    <input type="text" id="telefone" placeholder="5511999999999">
    <br>
    <br>
    Email:
    <input type="text" id="email">
    <br>
    <br>
    Médico:
    <input type="text" id="medico">
    <br>
    <br>
    Data:
    <input type="date" id="data">
    <br>
    <br>
    Hora:
    <input type="time" id="hora">
    <br>
    <br>

    <button onclick="enviarAviso()">Salvar Aviso</button>

    <hr>

    <h2>Lista de Avisos</h2>

    <table border="1" width="200%">
        <thead>
            <tr>
                <th>Paciente</th>
                <th>Médico</th>
                <th>Data</th>
                <th>Hora</th>
                <th>Ações</th>
            </tr>
        </thead>

        <tbody id="tabela"></tbody>
    </table>

    <hr>

    <h2>Status</h2>
    <div id="mensagem" style="border:1px solid black; padding:10px;">
        Nenhum aviso enviado
    </div>
    <div><a asp-controller="Home" asp-action="Financeiro">Painel Geral</a></div>
    <script>

        // carregar ao abrir
        window.onload = carregarAvisos;

        // SALVAR
        function enviarAviso() {

        let paciente = document.getElementById("paciente").value;
        let telefone = document.getElementById("telefone").value;
        let email = document.getElementById("email").value;
        let medico = document.getElementById("medico").value;
        let data = document.getElementById("data").value;
        let hora = document.getElementById("hora").value;

        let avisos = JSON.parse(localStorage.getItem("avisos")) || [];

        avisos.push({paciente, telefone, email, medico, data, hora});

        localStorage.setItem("avisos", JSON.stringify(avisos));

        // limpar formulário ✅
        document.getElementById("paciente").value = "";
        document.getElementById("telefone").value = "";
        document.getElementById("email").value = "";
        document.getElementById("medico").value = "";
        document.getElementById("data").value = "";
        document.getElementById("hora").value = "";

        carregarAvisos();

        document.getElementById("mensagem").innerText = "Aviso salvo com sucesso!";
        }

        // MOSTRAR TABELA
        function carregarAvisos() {

        let tabela = document.getElementById("tabela");
        tabela.innerHTML = "";

        let avisos = JSON.parse(localStorage.getItem("avisos")) || [];

        avisos.forEach((a, i) => {

        let mensagem = `Olá ${a.paciente}, sua consulta com ${a.medico} está marcada para ${a.data} às ${a.hora}`;

        let linha = tabela.insertRow();

        linha.innerHTML =
        "<td>" + a.paciente + "</td>" +
        "<td>" + a.medico + "</td>" +
        "<td>" + a.data + "</td>" +
        "<td>" + a.hora + "</td>" +
        "<td>" +

        "<button onclick='enviarWhats("+i+")'>WhatsApp</button> " +

        "<button onclick='enviarEmail("+i+")'>Email</button> " +

        "<button onclick='excluir("+i+")'>Excluir</button>" +

        "</td>";
        });
        }

        // WHATSAPP ✅
        function enviarWhats(i) {

        let avisos = JSON.parse(localStorage.getItem("avisos"));
        let a = avisos[i];

        let mensagem = `Olá ${a.paciente}, sua consulta com ${a.medico} está marcada para ${a.data} às ${a.hora}`;

        let url = "https://wa.me/" + a.telefone + "?text=" + encodeURIComponent(mensagem);

        window.open(url, "_blank");
        }

        // EMAIL ✅
        function enviarEmail(i) {

        let avisos = JSON.parse(localStorage.getItem("avisos"));
        let a = avisos[i];

        let mensagem = `Olá ${a.paciente}, sua consulta com ${a.medico} está marcada para ${a.data} às ${a.hora}`;

        let url = `mailto:${a.email}?subject=Consulta&body=${encodeURIComponent(mensagem)}`;

        window.location.href = url;
        }

        // EXCLUIR
        function excluir(i) {

        let avisos = JSON.parse(localStorage.getItem("avisos"));

        avisos.splice(i, 1);

        localStorage.setItem("avisos", JSON.stringify(avisos));

        carregarAvisos();
        }

    </script>
   
</body>
</html>